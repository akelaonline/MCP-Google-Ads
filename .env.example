# --- Google Ads API credentials ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=

# Only needed if you access client accounts through an MCC (manager) account
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Server behavior ---
# If true, mutate tools execute immediately without requiring
# confirm_pending_action(). Leave false for any account with real spend.
GOOGLE_ADS_MCP_AUTO_APPROVE=false

# How long a proposed (unconfirmed) action stays valid, in minutes
GOOGLE_ADS_MCP_PENDING_TTL_MINUTES=30

# Where the audit trail (SQLite) is written.
# Leave blank to use the default: ~/.google_ads_mcp/audit.db (safe regardless
# of which directory the MCP host launches the process from).
GOOGLE_ADS_MCP_AUDIT_DB=

# "stdio" (default, for Claude Desktop/Code) or "http"
GOOGLE_ADS_MCP_TRANSPORT=stdio
GOOGLE_ADS_MCP_HTTP_PORT=8080
